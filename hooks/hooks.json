{
  "description": "Codex Dev Orchestrator writer, secret, and production safety guardrails.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/run-hook.sh\"",
            "timeout": 10,
            "statusMessage": "Loading durable workflow state"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "^(planner|executor|reviewer|fixer|browser-verifier)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/run-hook.sh\"",
            "timeout": 10,
            "statusMessage": "Binding development assignment"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "^(planner|executor|reviewer|fixer|browser-verifier)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/run-hook.sh\"",
            "timeout": 10,
            "statusMessage": "Recording agent handoff"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/scripts/run-hook.sh\"",
            "timeout": 10,
            "statusMessage": "Checking workflow safety policy"
          }
        ]
      }
    ]
  }
}
